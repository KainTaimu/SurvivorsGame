; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SurvivorsGame"
run/main_scene="uid://68cq6qirfliu"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cd1ytmgy4kjgv"

[autoload]

DebugMenu="*uid://cggqb75a8w8r"
Game="*uid://brlugd2ju6667"
AudioManager="*uid://b6x82ongi5yps"
ServiceLocator="*res://scenes/Core/ServiceLocator.tscn"

[debug]

file_logging/enable_file_logging=true
shapes/navigation/2d/geometry_face_color=Color(0.49995556, 1, 1, 0.048)

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/resizable=false
window/stretch/mode="viewport"
window/vsync/vsync_mode=0
window/size/mode.editor=4

[dotnet]

project/assembly_name="Game"

[editor]

naming/default_signal_callback_name="On{node_name}{signal_name}"
naming/default_signal_callback_to_self_name="On{signal_name}"
naming/scene_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/rider-plugin/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://exports/": "gray",
"res://roslyn-source-generated:/": "gray"
}

[global_group]

