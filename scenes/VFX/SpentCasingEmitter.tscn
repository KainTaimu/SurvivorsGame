script/source = "extends GPUParticles2D

func spawn_casing():
	var case_transform = Transform2D(0, global_position)
	var velocity = Vector2.RIGHT.rotated(randf_range(0, 2 * PI))
	velocity *= randf_range(800,2000)
	emit_particle(case_transform, velocity, Color.WHITE, Color.WHITE, 
		EMIT_FLAG_POSITION
	)
"

