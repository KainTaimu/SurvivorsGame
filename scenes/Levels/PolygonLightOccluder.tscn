[gd_scene format=3 uid="uid://wos5frj6p77e"]

[sub_resource type="GDScript" id="GDScript_ps52f"]
script/source = "extends Polygon2D

@onready var occluder : LightOccluder2D = $LightOccluder2D
@onready var collider : CollisionPolygon2D = $StaticBody2D/CollisionPolygon2D

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	set_child_polygons()
	
func _input(_event: InputEvent) -> void:
	if Input.is_action_just_pressed(\"REGENERATE_NAVIGATION\"):
		set_child_polygons()

func set_child_polygons():
	call_deferred(\"set_occluder_polygon\")
	call_deferred(\"set_collision_polygon\")

func set_occluder_polygon():
	if (len(polygon) < 2):
		printerr($\"cannot set LightOccluder Polygon because len(polygon) < 2\")
		return
	occluder.occluder.polygon = polygon

func set_collision_polygon():
	if (len(polygon) < 2):
		printerr($\"cannot set LightOccluder Polygon because len(polygon) < 2\")
		return
	collider.polygon = polygon	
"

